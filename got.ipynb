    "def preprocess(text):\n",
    "\n",
    "    text = text.lower()\n",
    "    text = re.sub(r\"\\n+\", \" \", text)\n",
    "    text = re.sub(r'[^a-zA-Z\\s]', '', text)\n",
    "\n",
    "    return text\n",
    "\n",
    "\n",
    "clean_text = preprocess(text)"
